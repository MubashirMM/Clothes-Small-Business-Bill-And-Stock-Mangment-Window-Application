<Page x:Class="WpfApp2.Views.SuperAdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfApp2"
      mc:Ignorable="d"
      Title="Super Admin Dashboard"
      d:DesignWidth="1400" d:DesignHeight="800"
      Width="1400" Height="800">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#667eea" Offset="0"/>
                <GradientStop Color="#764ba2" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Opacity="0.95">
            <Grid>
                <TextBlock Text="👑 Super Admin Dashboard" 
                           FontSize="22" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#667eea"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0" VerticalAlignment="Center">
                    <Button Command="{Binding NavigateToAdminPageCommand}"
                            Content="📦 Manage Products"
                            FontSize="12"
                            Padding="10,5"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,10,0"/>

                    <Button Command="{Binding RefreshAllCommand}"
                            Content="🔄 Refresh All"
                            FontSize="12"
                            Padding="10,5"
                            Background="#2196F3"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,10,0"/>

                    <Button Command="{Binding BackToHomeCommand}"
                            Content="← Back to Home"
                            FontSize="12"
                            Padding="10,5"
                            Background="#667eea"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="20" SelectedIndex="{Binding SelectedTabIndex}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Padding" Value="25,12"/>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: Dashboard -->
            <TabItem Header="📊 Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <!-- Statistics Cards -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Card 1 -->
                            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="💰 Total Revenue" FontSize="14" Foreground="#666"/>
                                    <TextBlock Text="{Binding TotalRevenue, StringFormat={}{0:C2}}" 
                                               FontSize="28" FontWeight="Bold" Foreground="#4CAF50"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 2 -->
                            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="📦 Total Orders" FontSize="14" Foreground="#666"/>
                                    <TextBlock Text="{Binding TotalOrders}" 
                                               FontSize="28" FontWeight="Bold" Foreground="#2196F3"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 3 -->
                            <Border Grid.Column="4" Background="White" CornerRadius="10" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="👥 Total Users" FontSize="14" Foreground="#666"/>
                                    <TextBlock Text="{Binding TotalUsers}" 
                                               FontSize="28" FontWeight="Bold" Foreground="#FF9800"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 4 -->
                            <Border Grid.Column="6" Background="White" CornerRadius="10" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="🛍️ Total Products" FontSize="14" Foreground="#666"/>
                                    <TextBlock Text="{Binding TotalProducts}" 
                                               FontSize="28" FontWeight="Bold" Foreground="#9C27B0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Sales Report Section -->
                        <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="📈 Sales Report" FontSize="18" FontWeight="Bold"/>
                                    <ComboBox Grid.Column="1" 
                                              ItemsSource="{Binding PeriodOptions}"
                                              SelectedItem="{Binding SelectedPeriod}"
                                              Width="120" Padding="5"/>
                                </Grid>

                                <!-- Daily Sales -->
                                <DataGrid ItemsSource="{Binding DailySales}"
                                          AutoGenerateColumns="False"
                                          Visibility="{Binding SelectedPeriod, Converter={StaticResource StringToVisibilityConverter}}"
                                          MaxHeight="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Hour" Binding="{Binding Hour}" Width="100"/>
                                        <DataGridTextColumn Header="Orders" Binding="{Binding OrdersCount}" Width="100"/>
                                        <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat={}{0:C2}}" Width="150"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Weekly Sales -->
                                <DataGrid ItemsSource="{Binding WeeklySales}"
                                          AutoGenerateColumns="False"
                                          Visibility="{Binding SelectedPeriod, Converter={StaticResource StringToVisibilityConverter}}"
                                          MaxHeight="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=MMM dd}" Width="120"/>
                                        <DataGridTextColumn Header="Orders" Binding="{Binding OrdersCount}" Width="100"/>
                                        <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat={}{0:C2}}" Width="150"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Monthly Sales -->
                                <DataGrid ItemsSource="{Binding MonthlySales}"
                                          AutoGenerateColumns="False"
                                          Visibility="{Binding SelectedPeriod, Converter={StaticResource StringToVisibilityConverter}}"
                                          MaxHeight="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Month" Binding="{Binding MonthName}" Width="120"/>
                                        <DataGridTextColumn Header="Orders" Binding="{Binding OrdersCount}" Width="100"/>
                                        <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat={}{0:C2}}" Width="150"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <!-- Top Selling & Low Stock -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Top Selling Products -->
                            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="🏆 Top Selling Products" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <DataGrid ItemsSource="{Binding TopSellingProducts}"
                                              AutoGenerateColumns="False"
                                              MaxHeight="300">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="150"/>
                                            <DataGridTextColumn Header="Qty Sold" Binding="{Binding TotalQuantitySold}" Width="80"/>
                                            <DataGridTextColumn Header="Revenue" Binding="{Binding TotalRevenue, StringFormat={}{0:C2}}" Width="100"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Low Stock Products -->
                            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="⚠️ Low Stock Products (&lt;10)" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <DataGrid ItemsSource="{Binding LowStockProducts}"
                                              AutoGenerateColumns="False"
                                              MaxHeight="300">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Product" Binding="{Binding Name}" Width="150"/>
                                            <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="100"/>
                                            <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="80">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="Red"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Users Management -->
            <TabItem Header="👥 Users Management">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0" 
                             Text="{Binding SearchUserText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                             FontSize="14" 
                             Padding="10"
                             Margin="0,0,0,15"
                             Tag="Search by name or email..."/>

                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              RowHeight="40">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="60"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding UserName}" Width="150"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding UserEmail}" Width="200"/>
                            <DataGridTextColumn Header="Role" Binding="{Binding UserRole}" Width="120"/>
                            <DataGridTextColumn Header="Joined" Binding="{Binding UserJoiningDateTime, StringFormat='{}{MMM dd, yyyy}'}" Width="120"/>
                            <DataGridTextColumn Header="Orders" Binding="{Binding OrderCount}" Width="80"/>
                            <DataGridTextColumn Header="Total Spent" Binding="{Binding TotalSpent, StringFormat={}{0:C2}}" Width="120"/>

                            <DataGridTemplateColumn Header="Action" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="View Orders" 
                                                Background="#2196F3"
                                                Foreground="White"
                                                FontSize="10"
                                                Padding="8,5"
                                                Command="{Binding DataContext.ViewUserOrdersCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding UserId}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab 3: All Orders -->
            <TabItem Header="📋 All Orders">
                <Grid Margin="10">
                    <DataGrid ItemsSource="{Binding AllOrders}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              RowHeight="40">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="80"/>
                            <DataGridTextColumn Header="User" Binding="{Binding UserName}" Width="150"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding OrderDate, StringFormat='{}{MMM dd, yyyy hh:mm tt}'}" Width="180"/>
                            <DataGridTextColumn Header="Items" Binding="{Binding ItemCount}" Width="80"/> 
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat={}{0:C2}}" Width="120"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#2C3E50">
            <TextBlock Text="Super Admin Dashboard - Manage Users, Track Sales, View Analytics" 
                       Foreground="White" 
                       FontSize="11"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Loading Overlay -->
        <Border Background="#80000000" 
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                CornerRadius="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Loading..." Foreground="White" FontSize="16" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>