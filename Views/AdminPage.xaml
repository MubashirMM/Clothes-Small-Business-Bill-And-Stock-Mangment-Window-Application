<Page x:Class="WpfApp2.Views.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfApp2"
      mc:Ignorable="d"
      Title="Admin Panel - Product Management"
      d:DesignWidth="1200" d:DesignHeight="700"
      Width="1200" Height="700">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#667eea" Offset="0"/>
                <GradientStop Color="#764ba2" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Opacity="0.95">
            <Grid>
                <TextBlock Text="🛍️ Admin Panel - Product Management" 
                           FontSize="20" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#667eea"/>

                <Button Command="{Binding BackToHomeCommand}"
                        Content="← Back to Home"
                        FontSize="12"
                        Padding="10,5"
                        Background="#667eea"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,0"
                        VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#764ba2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Form -->
            <Border Grid.Column="0" 
                    Background="White" 
                    CornerRadius="10" 
                    Padding="15"
                    VerticalAlignment="Top">

                <StackPanel>
                    <TextBlock Text="📝 Product Form" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#667eea"
                               Margin="0,0,0,15"
                               HorizontalAlignment="Center"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="550">
                        <StackPanel>
                            <!-- Product Name -->
                            <TextBlock Text="Product Name *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13" Padding="8" Margin="0,0,0,10"/>

                            <!-- Brand -->
                            <TextBlock Text="Brand" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding Brand, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13" Padding="8" Margin="0,0,0,10"/>

                            <!-- Size and Color in one row -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Size" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <ComboBox ItemsSource="{Binding SizeList}"
                                              SelectedItem="{Binding Size}"
                                              FontSize="13" Padding="6"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Color" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding Color}" FontSize="13" Padding="6"/>
                                </StackPanel>
                            </Grid>

                            <!-- Material and Gender -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Material" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding Material}" FontSize="13" Padding="6"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Gender" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <ComboBox ItemsSource="{Binding GenderList}"
                                              SelectedItem="{Binding Gender}"
                                              FontSize="13" Padding="6"/>
                                </StackPanel>
                            </Grid>

                            <!-- Season and Price -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Season" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <ComboBox ItemsSource="{Binding SeasonList}"
                                              SelectedItem="{Binding Season}"
                                              FontSize="13" Padding="6"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Price ($)" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding Price}" FontSize="13" Padding="6"/>
                                </StackPanel>
                            </Grid>

                            <!-- Stock Quantity -->
                            <TextBlock Text="Stock Quantity" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding StockQuantity}" 
                                     FontSize="13" Padding="8" Margin="0,0,0,15"/>

                            <!-- ADD Button -->
                            <Button Command="{Binding SaveProductCommand}"
                                    Content="➕ ADD PRODUCT"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Padding="10"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Margin="0,0,0,10"
                                    Height="40">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- UPDATE Button -->
                            <Button Command="{Binding UpdateProductCommand}"
                                    Content="✏️ UPDATE PRODUCT"
                                    Background="#FF9800"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Padding="10"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Margin="0,0,0,10"
                                    Height="40">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- CLEAR Button -->
                            <Button Command="{Binding ClearFormCommand}"
                                    Content="🗑️ CLEAR FORM"
                                    Background="#9E9E9E"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Padding="10"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Margin="0,0,0,10"
                                    Height="40"/>

                            <!-- DELETE Button -->
                            <Button Command="{Binding DeleteProductCommand}"
                                    Content="🗑️ DELETE PRODUCT"
                                    Background="#F44336"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Padding="10"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Margin="0,5,0,0"
                                    Height="40">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Error Message -->
                            <TextBlock Text="{Binding ErrorMessage}" 
                                       Foreground="#D32F2F" 
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Separator -->
            <Border Grid.Column="1" Background="#E0E0E0" Width="1"/>

            <!-- Right Panel - Product Grid -->
            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="15">
                <StackPanel>
                    <!-- Search Bar -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" 
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                 FontSize="14" 
                                 Padding="10"
                                 Tag="🔍 Search by product name..."/>

                        <Button Grid.Column="1" 
                                Command="{Binding SearchCommand}"
                                Content="🔍 Search"
                                Background="#667eea"
                                Foreground="White"
                                Padding="15,10"
                                Margin="10,0,5,0"
                                BorderThickness="0"
                                Cursor="Hand"/>

                        <Button Grid.Column="2" 
                                Command="{Binding LoadProductsCommand}"
                                Content="🔄 Refresh"
                                Background="#4CAF50"
                                Foreground="White"
                                Padding="15,10"
                                Margin="5,0,0,0"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </Grid>

                    <!-- Products DataGrid with Action Buttons -->
                    <DataGrid ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal"
                              RowHeight="50"
                              Margin="0,10,0,0"
                              Height="500">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="50"/>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding Name}" Width="180"/>
                            <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="100"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="60"/>
                            <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="80"/>
                            <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="80"/>
                            <DataGridTextColumn Header="Season" Binding="{Binding Season}" Width="80"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:C2}}" Width="80"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="70"/>

                            <!-- Action Buttons Column -->
                            <DataGridTemplateColumn Header="Actions" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <!-- Edit Button -->
                                            <Button Content="✏️ Edit" 
                                                    Background="#FF9800"
                                                    Foreground="White"
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Padding="8,5"
                                                    Margin="2"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Tag="{Binding}"
                                                    Click="EditButton_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F57C00"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- Delete Button -->
                                            <Button Content="🗑️ Delete" 
                                                    Background="#F44336"
                                                    Foreground="White"
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Padding="8,5"
                                                    Margin="2"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Tag="{Binding}"
                                                    Click="DeleteButton_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#D32F2F"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>

                    <!-- Loading Overlay -->
                    <Border Background="#80000000" 
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                            CornerRadius="10">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Loading..." Foreground="White" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#2C3E50">
            <TextBlock Text="Admin Panel - Manage your products efficiently" 
                       Foreground="White" 
                       FontSize="11"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Page>