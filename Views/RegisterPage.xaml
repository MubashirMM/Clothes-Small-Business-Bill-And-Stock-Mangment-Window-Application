<Page x:Class="WpfApp2.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfApp2"
      mc:Ignorable="d"
      Title="Register"
      d:DesignWidth="480" d:DesignHeight="600"
      Width="480" Height="600">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4ECDC4" Offset="0"/>
                <GradientStop Color="#556270" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Opacity="0.95">
            <TextBlock Text="Create New Account" 
                       FontSize="22" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#4ECDC4"/>
        </Border>

        <!-- Registration Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White"
                    CornerRadius="15"
                    Margin="30,15,30,25"
                    Padding="25">

                <StackPanel>
                    <!-- Username Field -->
                    <TextBlock Text="Username" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                             FontSize="13"
                             Padding="8"
                             Margin="0,0,0,3"/>
                    <TextBlock Text="{Binding FieldErrors[UserName]}" 
                               Foreground="#D32F2F" 
                               FontSize="10"
                               Margin="5,0,0,10"
                               Visibility="{Binding FieldErrors[UserName], Converter={StaticResource StringToVisibilityConverter}}"/>

                    <!-- Email Field -->
                    <TextBlock Text="Email Address" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <TextBox Text="{Binding UserEmail, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                             FontSize="13"
                             Padding="8"
                             Margin="0,0,0,3"/>
                    <TextBlock Text="{Binding FieldErrors[UserEmail]}" 
                               Foreground="#D32F2F" 
                               FontSize="10"
                               Margin="5,0,0,10"
                               Visibility="{Binding FieldErrors[UserEmail], Converter={StaticResource StringToVisibilityConverter}}"/>

                    <!-- Password Field -->
                    <TextBlock Text="Password" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox"
                                 FontSize="13"
                                 Padding="8"
                                 Margin="0,0,0,3"/>
                    <TextBlock Text="{Binding FieldErrors[UserPassword]}" 
                               Foreground="#D32F2F" 
                               FontSize="10"
                               Margin="5,0,0,10"
                               Visibility="{Binding FieldErrors[UserPassword], Converter={StaticResource StringToVisibilityConverter}}"/>

                    <!-- Confirm Password Field -->
                    <TextBlock Text="Confirm Password" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 FontSize="13"
                                 Padding="8"
                                 Margin="0,0,0,3"/>
                    <TextBlock Text="{Binding FieldErrors[ConfirmPassword]}" 
                               Foreground="#D32F2F" 
                               FontSize="10"
                               Margin="5,0,0,10"
                               Visibility="{Binding FieldErrors[ConfirmPassword], Converter={StaticResource StringToVisibilityConverter}}"/>

                    <!-- Role Selection -->
                    <TextBlock Text="User Role" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding UserRoles}"
                              SelectedItem="{Binding SelectedUserRole}"
                              FontSize="13"
                              Padding="8"
                              Margin="0,0,0,15"/>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="#D32F2F" 
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                    <!-- Password Requirements -->
                    <Border Background="#FFF9E6" 
                            Padding="8" 
                            Margin="0,0,0,15"
                            CornerRadius="5">
                        <TextBlock FontSize="10" 
                                   Foreground="#856404"
                                   TextWrapping="Wrap">
                            <Run Text="🔒 Password requirements: "/>
                            <Run Text="8-12 chars, 1 uppercase, 1 lowercase, 1 number, 1 special (@$!%*?&amp;)"/>
                        </TextBlock>
                    </Border>

                    <!-- Register Button -->
                    <Button Command="{Binding RegisterCommand}"
                            Content="CREATE ACCOUNT"
                            FontSize="14"
                            FontWeight="Bold"
                            Padding="10"
                            Background="#4ECDC4"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,0,10">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#4ECDC4"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#45B7B0"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#CCCCCC"/>
                                        <Setter Property="Foreground" Value="#999999"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Back Button -->
                    <Button Command="{Binding BackToHomeCommand}"
                            Content="← Back to Home"
                            FontSize="12"
                            Padding="6"
                            Background="Transparent"
                            Foreground="#4ECDC4"
                            BorderBrush="#4ECDC4"
                            BorderThickness="1"
                            Cursor="Hand"
                            Margin="0,5,0,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#4ECDC4"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Background="#CC000000" 
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Creating account..." Foreground="White" FontSize="16" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>