<Page x:Class="WpfApp2.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfApp2"
      mc:Ignorable="d"
      Title="Login"
      d:DesignWidth="400" d:DesignHeight="450"
      Width="400" Height="450">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF6B6B" Offset="0"/>
                <GradientStop Color="#FF8E53" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Opacity="0.95">
            <TextBlock Text="Login to Your Account" 
                       FontSize="20" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#FF6B6B"/>
        </Border>

        <!-- Login Form -->
        <Border Grid.Row="1" 
                Background="White"
                CornerRadius="15"
                Margin="30,20,30,30"
                Padding="25">

            <StackPanel>
                <!-- Email -->
                <TextBlock Text="Email Address" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding UserEmail, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                         FontSize="13" Padding="10" Margin="0,0,0,15"/>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox"
                             FontSize="13" Padding="10" Margin="0,0,0,15"/>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="#D32F2F" FontSize="10"
                           TextWrapping="Wrap" Margin="0,0,0,15"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Login Button -->
                <Button Command="{Binding LoginCommand}"
                        Content="LOGIN"
                        FontSize="13" FontWeight="Bold" Padding="10"
                        Background="#FF6B6B" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,0,10">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FF6B6B"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF5252"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                    <Setter Property="Foreground" Value="#999999"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Back Button -->
                <Button Command="{Binding BackToHomeCommand}"
                        Content="← Back to Home"
                        FontSize="11" Padding="6"
                        Background="Transparent" Foreground="#FF6B6B"
                        BorderBrush="#FF6B6B" BorderThickness="1"
                        Cursor="Hand" Margin="0,5,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF6B6B"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Background="#CC000000" 
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Logging in..." Foreground="White" FontSize="14" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>