<Page x:Class="WpfApp2.Views.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfApp2"
      mc:Ignorable="d"
      Title="User Dashboard"
      d:DesignWidth="1200" d:DesignHeight="700"
      Width="1200" Height="700">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4ECDC4" Offset="0"/>
                <GradientStop Color="#556270" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Opacity="0.95">
            <Grid>
                <TextBlock Text="🛍️ User Dashboard - Shop Now" 
                           FontSize="20" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#4ECDC4"/>

                <Button Command="{Binding BackToHomeCommand}"
                        Content="← Back to Home"
                        FontSize="12"
                        Padding="10,5"
                        Background="#4ECDC4"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,0"
                        VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#45B7B0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="20" SelectedIndex="{Binding SelectedTabIndex}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Padding" Value="20,10"/>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: Shop -->
            <TabItem Header="🛒 Shop Products">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search Bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" 
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                 FontSize="14" 
                                 Padding="10"
                                 Background="White"
                                 Foreground="Black"/>
                        <TextBlock Grid.Column="0" 
                                   Text="🔍 Search by product name..." 
                                   FontSize="14" 
                                   Padding="10"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}}"/>

                        <Button Grid.Column="1" 
                                Command="{Binding SearchCommand}"
                                Content="🔍 Search"
                                Background="#4ECDC4"
                                Foreground="White"
                                FontWeight="Bold"
                                Padding="15,10"
                                Margin="10,0,5,0"
                                BorderThickness="0"
                                Cursor="Hand"/>

                        <Button Grid.Column="2" 
                                Command="{Binding LoadProductsCommand}"
                                Content="🔄 Refresh"
                                Background="#4CAF50"
                                Foreground="White"
                                FontWeight="Bold"
                                Padding="15,10"
                                Margin="5,0,0,0"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </Grid>

                    <!-- Products Grid -->
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid ItemsSource="{Binding Products}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="50"
                                  Background="White"
                                  MinWidth="900">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="50"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180"/>
                                <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="120"/>
                                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="70"/>
                                <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="90"/>
                                <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="90"/>
                                <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:C2}}" Width="100"/>
                                <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="80"/>

                                <DataGridTemplateColumn Header="Action" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="➕ Add to Cart" 
                                                    Background="#4ECDC4"
                                                    Foreground="White"
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Padding="10,5"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Tab 2: Cart -->
            <TabItem Header="🛍️ Shopping Cart">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cart Grid -->
                    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <DataGrid ItemsSource="{Binding CartItems}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="50"
                                  Background="White"
                                  MinWidth="700">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="200"/>
                                <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:C2}}" Width="100"/>
                                <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat={}{0:C2}}" Width="100"/>

                                <DataGridTemplateColumn Header="Quantity" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="-" 
                                                        Width="30" Height="30"
                                                        Background="#F44336"
                                                        Foreground="White"
                                                        FontWeight="Bold"
                                                        FontSize="14"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"/>

                                                <TextBlock Text="{Binding Quantity}" 
                                                           Width="40" 
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="14" 
                                                           FontWeight="Bold"
                                                           Foreground="Black"/>

                                                <Button Content="+" 
                                                        Width="30" Height="30"
                                                        Background="#4CAF50"
                                                        Foreground="White"
                                                        FontWeight="Bold"
                                                        FontSize="14"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat={}{0:C2}}" Width="100"/>

                                <DataGridTemplateColumn Header="Action" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Remove" 
                                                    Background="#FF9800"
                                                    Foreground="White"
                                                    FontSize="10"
                                                    FontWeight="Bold"
                                                    Padding="8,5"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>

                    <!-- Bill Summary -->
                    <Border Grid.Row="1" Background="#FFF9E6" CornerRadius="10" Padding="15" Margin="0,15,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="TOTAL BILL:" 
                                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center"
                                       Foreground="#333333"/>

                            <TextBlock Grid.Column="1" Text="{Binding TotalBill, StringFormat={}{0:C2}}" 
                                       FontSize="24" FontWeight="Bold" Foreground="#4CAF50"
                                       Margin="20,0"/>

                            <Button Grid.Column="2"
                                    Command="{Binding GenerateBillCommand}"
                                    Content="💰 GENERATE BILL"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Padding="15,10"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                        </Grid>
                    </Border>

                    <!-- Empty Cart Message -->
                    <TextBlock Grid.Row="2" 
                               Text="Your cart is empty. Add some products!" 
                               FontSize="14" 
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0"
                               Visibility="{Binding CartItems.Count, Converter={StaticResource StringToVisibilityConverter}}"/>
                </Grid>
            </TabItem>

            <!-- Tab 3: Order History -->
            <TabItem Header="📜 Order History">
                <Grid Margin="10">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid ItemsSource="{Binding OrderHistory}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="50"
                                  Background="White"
                                  MinWidth="800">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="80"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding OrderDate, StringFormat='MMM dd, yyyy hh:mm tt'}" Width="180"/>
                                <DataGridTextColumn Header="Total Amount" Binding="{Binding TotalAmount, StringFormat={}{0:C2}}" Width="120"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding OrderStatus}" Width="100"/>
                                <DataGridTextColumn Header="Items" Binding="{Binding OrderItems.Count}" Width="80"/>

                                <DataGridTemplateColumn Header="Actions" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="View Details" 
                                                        Background="#2196F3"
                                                        Foreground="White"
                                                        FontSize="10"
                                                        FontWeight="Bold"
                                                        Padding="8,5"
                                                        Margin="2"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.ViewOrderDetailsCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"/>

                                                <Button Content="View PDF" 
                                                        Background="#FF9800"
                                                        Foreground="White"
                                                        FontSize="10"
                                                        FontWeight="Bold"
                                                        Padding="8,5"
                                                        Margin="2"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.ViewPDFCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#2C3E50">
            <TextBlock Text="User Dashboard - Shop, Add to Cart, Generate Bills &amp; View History" 
                       Foreground="White" 
                       FontSize="11"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Loading Overlay -->
        <Border Background="#80000000" 
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                CornerRadius="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Loading..." Foreground="White" FontSize="16" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>